# ไฟล์นี้เป็น EXAMPLE — ห้าม commit ขึ้น git โดยไม่ encrypt
# copy แล้วแก้ค่า จากนั้น apply และลบทิ้ง
#
# สร้างด้วย kubectl:
#   kubectl create secret generic cubejs-db-secret \
#     --namespace oncb-app1-platform \
#     --from-literal=CUBEJS_DB_HOST="db.internal.oncb.go.th" \
#     --from-literal=CUBEJS_DB_USER="cubejs_user" \
#     --from-literal=CUBEJS_DB_PASS="your-password"
#
# หรือ apply ไฟล์นี้:
#   kubectl apply -f cubejs-db-secret.yaml
#
apiVersion: v1
kind: Secret
metadata:
  name: cubejs-db-secret
  namespace: oncb-app1-platform
  labels:
    app: cubejs
    managed-by: manual
type: Opaque
stringData:
  CUBEJS_DB_HOST: "db.internal.oncb.go.th"
  CUBEJS_DB_USER: "cubejs_user"
  CUBEJS_DB_PASS: "your-password"
