# ไฟล์นี้เป็น EXAMPLE เท่านั้น — ห้าม commit ขึ้น git โดยไม่ encrypt
# ให้ copy และแก้ไข credentials จริงก่อน apply
#
# apply ด้วย:
#   kubectl apply -f cubestore-objectstorage-secret.yaml -n oncb-app1-platform
#
# ลบหลัง apply แล้ว:
#   rm cubestore-objectstorage-secret.yaml
#
apiVersion: v1
kind: Secret
metadata:
  name: cubestore-objectstorage-secret
  namespace: oncb-app1-platform
  labels:
    app: cubestore
    managed-by: manual
type: Opaque
stringData:
  CUBESTORE_AWS_ACCESS_KEY_ID: "<your-ceph-access-key>"
  CUBESTORE_AWS_SECRET_ACCESS_KEY: "<your-ceph-secret-key>"
