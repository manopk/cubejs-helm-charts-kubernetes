# Secret สำหรับ oncb_app1_cubejs (External Pre-aggregation Database)
# ห้าม commit ขึ้น git โดยไม่ encrypt
#
# สร้างด้วย kubectl:
#   kubectl create secret generic cubejs-ext-db-secret \
#     --namespace oncb-app1-platform \
#     --from-literal=CUBEJS_EXT_DB_HOST="db2.internal.oncb.go.th" \
#     --from-literal=CUBEJS_EXT_DB_USER="cubejs_ext_user" \
#     --from-literal=CUBEJS_EXT_DB_PASS="your-ext-password"
#
apiVersion: v1
kind: Secret
metadata:
  name: cubejs-ext-db-secret
  namespace: oncb-app1-platform
  labels:
    app: cubejs
    managed-by: manual
type: Opaque
stringData:
  CUBEJS_EXT_DB_HOST: "db2.internal.oncb.go.th"
  CUBEJS_EXT_DB_USER: "cubejs_ext_user"
  CUBEJS_EXT_DB_PASS: "your-ext-password"
